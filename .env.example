# ── Database (Railway auto-provides this) ─────────────────
DATABASE_URL="postgresql://user:pass@host:5432/soullink"

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET="minimum-32-characters-random-secret-key"
JWT_EXPIRES_IN="30d"

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
ALLOWED_ORIGINS="*"

# ── Agora (https://console.agora.io) ────────────────────────
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_certificate_here

# ── Redis (Railway Redis plugin auto-provides) ───────────────
REDIS_URL=redis://localhost:6379

# ── OTP ─────────────────────────────────────────────────────
OTP_DEV_MODE=true
OTP_DEV_CODE=123456

# ── Cloudinary (optional — for avatar upload) ───────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Twilio (optional — for real OTP SMS) ────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
